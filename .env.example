# Hermes_Zalo — copy into %LOCALAPPDATA%\hermes\.env

ZALO_ENABLED=true
ZALO_BRIDGE_PORT=3001

# Prefer Zalo user IDs (from bridge logs / first DM). * = everyone (dev only).
# ZALO_ALLOWED_USERS=*
ZALO_ALLOWED_USERS=YOUR_ZALO_UID
ZALO_ALLOW_ALL_USERS=false

ZALO_FORWARD_SELF_MESSAGES=true
ZALO_SEND_SEEN=true
ZALO_POLL_INTERVAL=0.4

ZALO_HOME_CHANNEL=YOUR_ZALO_UID
ZALO_HOME_CHANNEL_NAME=Me
